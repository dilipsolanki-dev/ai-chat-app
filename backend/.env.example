# Copy this file to `.env` and fill in real values.  `cp .env.example .env`
# .env is gitignored — never commit real secrets.

# PostgreSQL (async driver). Matches the role/db you create in Phase 4.
DATABASE_URL=postgresql+asyncpg://ai_chat:ai_chat@localhost:5432/ai_chat

# ── LLM provider (any OpenAI-compatible API) ──────────────────────────────────
# Default = GROQ: free, no credit card. Get a key at https://console.groq.com (gsk_...)
OPENAI_API_KEY=gsk_your-groq-key-here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# Fake AI replies (no API calls / no cost). true = no key needed; flip to false to
# use the real provider configured above.
USE_MOCK_AI=false

# Other providers (same three vars, just different values):
#   Real OpenAI:  OPENAI_BASE_URL=  (empty) | OPENAI_MODEL=gpt-4o-mini      | sk- key
#   Hugging Face: OPENAI_BASE_URL=https://router.huggingface.co/v1         | hf_ key

# Frontend origin allowed by CORS (Vite dev server)
FRONTEND_ORIGIN=http://localhost:5173
