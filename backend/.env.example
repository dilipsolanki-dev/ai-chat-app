# Copy this file to `.env` and fill in real values.  `cp .env.example .env`
# .env is gitignored — never commit real secrets.

# PostgreSQL (async driver). Matches the role/db you create in Phase 4.
DATABASE_URL=postgresql+asyncpg://ai_chat:ai_chat@localhost:5432/ai_chat

# OpenAI (used in Phase 5). Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Fake AI replies (no API calls / no cost) while learning. Set to false once you
# have a real key with credit to use the actual OpenAI API.
USE_MOCK_AI=true

# Frontend origin allowed by CORS (Vite dev server)
FRONTEND_ORIGIN=http://localhost:5173
